{
  "name": "vertice",
  "version": "0.1.0",
  "private": true,
  "description": "Vértice — sistema premium de asistencia, operación y datos para RH multi-sede.",
  "license": "MIT",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm --filter @vertice/web dev",
    "dev:mobile": "pnpm --filter @vertice/mobile start",
    "build:web": "pnpm --filter @vertice/web build",
    "typecheck": "pnpm -r --parallel typecheck",
    "lint": "pnpm -r --parallel lint",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:gen-types": "supabase gen types typescript --local --schema public > packages/shared/src/database.types.ts",
    "import:legacy": "node scripts/import-legacy.mjs",
    "import:legacy:dry": "node scripts/import-legacy.mjs --dry-run"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "typescript": "^5.6.0",
    "xlsx": "^0.18.5"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.2.0",
      "@types/react-dom": "^19.2.0"
    }
  }
}
