# Copia este archivo a .env.local en cada app y rellena los valores reales.
# NUNCA commitees el archivo .env.local — está en .gitignore.

# ============================================================
# Supabase (web + mobile + edge functions)
# ============================================================

# URL pública del proyecto Supabase, p.ej. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_URL=

# Clave pública anon (segura para exponer en cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Clave de service role (SOLO servidor / scripts admin — JAMÁS en cliente)
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Configuración operativa
# ============================================================

# Hora local de la operación (timezone IANA)
TZ=America/Mexico_City

# Salario diario base usado para el cálculo de descuento por falta
NEXT_PUBLIC_SALARIO_DIARIO_DEFAULT=393.80
